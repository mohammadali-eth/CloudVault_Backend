generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  files            File[]
}

model File {
  id        String   @id @default(uuid())
  name      String
  url       String
  size      Int
  type      String
  path      String   @default("/")
  isFolder  Boolean  @default(false)
  provider  String   @default("google-drive")
  providerFileId String?
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
}
